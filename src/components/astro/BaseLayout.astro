---
import "global.scss";
import { OgImage } from "@imagekit/astro";
import Font from "astro/components/Font.astro";
import BreadCrumbs from "@/react/BreadCrumbs";
import Grid from "@/react/Grid";

interface BreadcrumbItem {
  url?: string;
  name: string;
}

interface Props {
  title: string;
  metaDescription?: string;
  canonicalUrl: string | URL;
  breadcrumbItems: BreadcrumbItem[];
}

const {
  title = "Junayd Bhoyroo",
  metaDescription = "Junayd Bhoyroo's portfolio",
  canonicalUrl = Astro.site,
  breadcrumbItems = [{ name: "Junayd Bhoyroo", url: "/" }],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      const theme = "light";

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }

      localStorage.setItem("theme", theme);

      window.addEventListener("storage", (event) => {
        if (event.key === "theme") {
          const isDark = event.newValue === "dark";
          if (isDark) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        }
      });
    </script>
    <Font cssVariable="--font-jetbrains-mono" preload />
    <Font cssVariable="--font-ibm-plex-mono" />
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <OgImage
      src="/web/brand-gradient.jpg"
      alt="Brand gradient"
      title={title}
      description={metaDescription}
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <Grid>
        <BreadCrumbs items={breadcrumbItems} />
      </Grid>
      <slot />
    </main>
    <div class="bg-grid"></div>
  </body>
</html>

<style>
  :global(body) {
    position: relative;
    max-width: none;
  }

  main {
    max-width: 80ch;
    position: relative;
    z-index: 1;
  }

  .bg-grid {
    --bg-grid-line: rgba(96, 96, 96, 0.02);

    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    margin: 0px;
    background-image:
      repeating-linear-gradient(
        var(--bg-grid-line) 0 1px,
        transparent 1px 100%
      ),
      repeating-linear-gradient(
        90deg,
        var(--bg-grid-line) 0 1px,
        transparent 1px 100%
      );
    background-size: 1ch calc(var(--theme-line-height-base) * 1rem);
    pointer-events: none;
    display: block;
  }

  @media (color-gamut: p3) {
    .bg-grid {
      --bg-grid-line: rgba(120, 120, 120, 0.1);
    }
  }
</style>
