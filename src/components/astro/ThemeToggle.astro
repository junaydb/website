---
import ActionButton from "@/react/ActionButton";
import Icons from "@/react/Icons";

const SunIcon = Icons.sun;
const MoonIcon = Icons.moon;
---

<ActionButton id="theme-toggle" aria-label="Switch theme">
  <span class="theme-toggle-icon theme-toggle-icon-light" aria-hidden="true">
    <SunIcon />
  </span>
  <span class="theme-toggle-icon theme-toggle-icon-dark" aria-hidden="true">
    <MoonIcon />
  </span>
</ActionButton>

<script is:inline>
  const themeToggle = document.getElementById("theme-toggle");

  const syncThemeToggle = () => {
    const isDark = document.documentElement.classList.contains("dark");
    themeToggle?.setAttribute(
      "aria-label",
      isDark ? "Switch to light theme" : "Switch to dark theme",
    );
  };

  const handleToggleClick = () => {
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    syncThemeToggle();
  };

  themeToggle?.addEventListener("click", handleToggleClick);
  themeToggle?.addEventListener("keydown", (event) => {
    if (event.key === "Enter" || event.key === " ") {
      if (event.key === " ") event.preventDefault();
      handleToggleClick();
    }
  });
  syncThemeToggle();
</script>

<style>
  :global(#theme-toggle) {
    line-height: calc(var(--theme-line-height-base, 1.25) * 1rem);
    vertical-align: top;
  }

  :global(#theme-toggle > span) {
    align-items: center;
    display: inline-flex;
    height: calc(var(--theme-line-height-base, 1.25) * 1rem);
    justify-content: center;
    overflow: hidden;
  }

  :global(#theme-toggle svg) {
    display: block;
    height: 1em;
    width: 1em;
  }

  :global(.theme-toggle-icon) {
    display: inline-flex;
    flex: 0 0 auto;
  }

  :global(.theme-toggle-icon-dark) {
    display: none;
  }

  :global(html.dark .theme-toggle-icon-light) {
    display: none;
  }

  :global(html.dark .theme-toggle-icon-dark) {
    display: inline-flex;
  }
</style>
