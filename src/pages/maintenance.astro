---
import BaseLayout from "@/astro/BaseLayout.astro";
import Grid from "@/components/react/Grid";

const src =
  "https://ik.imagekit.io/xqhypdkfa/explorers-room/initial_blockout.png";
---

<BaseLayout title="BACK SOON">
  <Grid>
    <p>This site is under maintenance. Check back soon.</p>
    <br />
    <img
      src={`${src}/tr:w-600`}
      alt="Wireframes"
      loading="eager"
      srcset={`
${src}/tr:w-600,q-100 600w,
${src}/tr:w-1200,q-100 1200w
      `}
      sizes="(max-width: 768px) 90vw, 600px"
    />
  </Grid>
</BaseLayout>

<style>
  img {
    width: 100%;
    height: auto;
  }
</style>
