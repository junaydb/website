{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-24",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "404-page"
  },
  "vars": {
    "MAINTENANCE": "0",
  }
}
